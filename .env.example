# Copy to .env.local and fill in keys from:
# https://supabase.com/dashboard/project/ekdeizmxgucpvcrmoftz/settings/api

# Supabase - Amor Travel (project ref: ekdeizmxgucpvcrmoftz)
NEXT_PUBLIC_SUPABASE_URL=https://ekdeizmxgucpvcrmoftz.supabase.co
# Dashboard: Project Settings -> API -> anon public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-only (never expose to the browser or commit)
# Dashboard: Project Settings -> API -> service_role secret
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Apply Phase 2 schema after .env.local is set (requires database password):
#   supabase link --project-ref ekdeizmxgucpvcrmoftz -p YOUR_DB_PASSWORD
#   supabase db push --linked --include-all
# Or run SQL in Dashboard -> SQL Editor:
#   supabase/migrations/20260623000000_initial_phase2_schema.sql

# Optional - later phases
# GEMINI_API_KEY=
# RESEND_API_KEY=
# TRAVELPAYOUTS_TOKEN=
